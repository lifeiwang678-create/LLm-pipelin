{
  "run_name": "wesad_feature_fewshot_label_only",
  "labels": [
    0,
    1
  ],
  "output_dir": "outputs_modular",
  "data": {
    "train_subjects": [
      "S2",
      "S3",
      "S4",
      "S5",
      "S6"
    ],
    "test_subjects": [
      "S7",
      "S8"
    ]
  },
  "input": {
    "type": "feature_description",
    "data_dir": "..",
    "pattern": "*_features_paperstyle.csv"
  },
  "lm_usage": {
    "type": "few_shot",
    "n_per_class": 2,
    "random_state": 42,
    "example_selection": "leave_one_subject_out",
    "example_subjects": 3,
    "examples_per_subject_per_label": 1,
    "exclude_eval_subject": true
  },
  "output": {
    "type": "label_only"
  },
  "lm_client": {
    "api_url": "http://127.0.0.1:1234/v1",
    "api_key": "lm-studio",
    "model": "qwen2.5-14b-instruct",
    "temperature": 0.0,
    "max_tokens": 128,
    "timeout": 300
  },
  "evaluation": {
    "balanced_per_label": 10,
    "log_every": 10
  }
}
