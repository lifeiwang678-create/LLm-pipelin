{
  "run_name": "wesad_feature_multiagent_label_explanation",
  "labels": [1, 2],
  "output_dir": "outputs_modular",
  "data": {
    "subjects": ["S2", "S3"]
  },
  "input": {
    "type": "feature_description",
    "data_dir": ".",
    "pattern": "*_features_paperstyle.csv"
  },
  "lm_usage": {
    "type": "multi_agent",
    "agents": ["eda_agent", "cardio_resp_agent", "motion_temp_agent"],
    "final_decider": "decision_maker"
  },
  "output": {
    "type": "label_explanation",
    "fallback_label": 1
  },
  "lm_client": {
    "api_url": "http://127.0.0.1:1234/v1",
    "api_key": "lm-studio",
    "model": "qwen2.5-14b-instruct",
    "temperature": 0.0,
    "max_tokens": 192,
    "timeout": 30
  },
  "evaluation": {
    "per_subject_limit": 20,
    "log_every": 10
  }
}

